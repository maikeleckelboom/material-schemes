{
  "name": "material-schemes",
  "version": "0.0.0",
  "description": "TypeScript utilities for generating Material 3 color schemes, tonal palettes, and CSS variables.",
  "license": "MIT",
  "author": "Maikel Eckelboom",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maikeleckelboom/material-schemes.git"
  },
  "bugs": {
    "url": "https://github.com/maikeleckelboom/material-schemes/issues"
  },
  "homepage": "https://github.com/maikeleckelboom/material-schemes#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "material-design",
    "material-3",
    "color-schemes",
    "tonal-palettes",
    "css-variables",
    "design-tokens"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "check": "pnpm typecheck && pnpm test && pnpm build && pnpm format",
    "smoke:consumer": "node scripts/smokeConsumer.ts",
    "release:check": "pnpm check && pnpm pack --dry-run && pnpm smoke:consumer",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
