{
  "name": "@chromavert/material",
  "description": "Core utilities for generating and manipulating Material 3 color schemes",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "require": "./dist/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maikeleckelboom/material-schemes.git",
    "directory": "packages/core"
  },
  "author": "Maikel Eckelboom",
  "keywords": [
    "material-design",
    "material-3",
    "color-schemes",
    "design-tokens",
    "color-science",
    "theme-generation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "test": "vitest",
    "test:browser": "vitest --browser",
    "dev": "vitest --watch",
    "build": "tsup"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.4.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.3.0",
    "camelcase": "^8.0.0",
    "kebab-case": "^2.0.2",
    "vitest": "^3.1.1"
  }
}
