{
  "name": "@chromavert/material-cli",
  "description": "🚀 CLI tool for generating complete, customizable Material 3 color schemes with automatic dark/light mode support",
  "version": "0.1.0-alpha.0",
  "type": "module",
  "module": "src/index.ts",
  "bin": {
    "material-cli": "src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maikeleckelboom/material-schemes.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepublishOnly": "bun run build",
    "test": "vitest",
    "lint": "bun check src"
  },
  "keywords": [
    "material-design",
    "material-3",
    "color-schemes",
    "cli",
    "command-line",
    "design-tokens",
    "design-systems",
    "theme-generator"
  ],
  "author": "Maikel Eckelboom",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.4.1",
    "@chromavert/material-schemes": "workspace:*",
    "colorjs.io": "^0.5.2",
    "commander": "13.1.0",
    "dedent": "^1.5.3",
    "ora": "^8.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/dedent": "^0.7.2",
    "typescript": "^5.3.3",
    "vitest": "^3.1.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
